{
  "name": "@amitdevx/md2pdf",
  "version": "0.5.0",
  "description": "Production-quality Markdown to PDF rendering engine",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "bin": {
    "md2pdf": "dist/cli/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prebuild": "node scripts/build-katex-css.mjs",
    "build": "tsup && tsc -p tsconfig.build.json --emitDeclarationOnly",
    "dev": "tsup --watch",
    "pretest": "node scripts/build-katex-css.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "bench:mermaid": "node dist/cli/index.js tests/benchmarks/mermaid-50-diagrams.md -o tests/output/mermaid-bench.pdf",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist/",
    "prepare": "husky install || true",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/amitdevx/md2pdf.git"
  },
  "homepage": "https://github.com/amitdevx/md2pdf#readme",
  "bugs": {
    "url": "https://github.com/amitdevx/md2pdf/issues"
  },
  "keywords": [
    "markdown",
    "pdf",
    "generator",
    "playwright",
    "unified",
    "remark",
    "rehype"
  ],
  "author": "Amit Divekar",
  "license": "MIT",
  "dependencies": {
    "@shikijs/rehype": "^4.3.0",
    "commander": "^11.1.0",
    "gray-matter": "^4.0.3",
    "jiti": "^2.7.0",
    "js-yaml": "^5.2.1",
    "katex": "^0.16.47",
    "mermaid": "^11.16.0",
    "mime-types": "^3.0.2",
    "ora": "^5.4.1",
    "pdf-lib": "^1.17.1",
    "picocolors": "^1.0.0",
    "playwright-core": "^1.61.1",
    "rehype-katex": "^7.0.1",
    "rehype-slug": "^6.0.0",
    "rehype-stringify": "^10.0.0",
    "remark-gfm": "^4.0.0",
    "remark-math": "^6.0.0",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.0.0",
    "shiki": "^4.3.0",
    "unified": "^11.0.4",
    "unist-util-visit": "^5.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/hast": "^3.0.4",
    "@types/js-yaml": "^4.0.9",
    "@types/mime-types": "^3.0.1",
    "@types/node": "^20.10.0",
    "eslint": "^9.0.0",
    "husky": "^8.0.3",
    "lint-staged": "^15.1.0",
    "prettier": "^3.1.0",
    "tsup": "^8.0.1",
    "typescript": "^5.3.2",
    "typescript-eslint": "^8.0.0",
    "vitest": "^0.34.6"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "allowScripts": {
    "esbuild@0.27.7": true,
    "esbuild@0.21.5": true
  }
}
